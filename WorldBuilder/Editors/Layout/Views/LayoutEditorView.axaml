<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:WorldBuilder.Editors.Layout"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
             x:Class="WorldBuilder.Editors.Layout.Views.LayoutEditorView"
             x:DataType="vm:LayoutEditorViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.prop-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#8a7a9e" />
            <Setter Property="Width" Value="120" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.prop-value">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#c0b0d8" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#c0b0d8" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <!-- Status bar -->
        <Border DockPanel.Dock="Top" Background="#120c22" BorderBrush="#2a1d42" BorderThickness="0,0,0,1" Padding="8,4">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="Save layout to project"
                        Command="{Binding SaveLayoutToProjectCommand}"
                        Padding="12,4" FontSize="11" Margin="12,0,0,0"
                        ToolTip.Tip="Stores the current layout in the project (ui_layouts). Export DATs to write client_local_English.dat." />
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#8a7a9e"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="220,1,360,1,*">

            <!-- Column 0: Layout List -->
            <DockPanel Grid.Column="0" Background="#1a1030">
                <Border DockPanel.Dock="Top" Background="#120c22" Padding="6,6"
                        BorderBrush="#2a1d42" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="UI Layouts" FontSize="13" FontWeight="SemiBold" Foreground="#c0b0d8" />
                        <TextBox Text="{Binding SearchText}" FontSize="11" Padding="4,3"
                                 Watermark="Filter by hex ID" />
                    </StackPanel>
                </Border>
                <ListBox ItemsSource="{Binding FilteredLayouts}"
                         SelectedItem="{Binding SelectedLayout}"
                         Background="Transparent" FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LayoutListItem">
                            <TextBlock Text="{Binding DisplayId}" FontFamily="Consolas"
                                       Foreground="#c0b0d8" FontSize="11" Margin="4,2" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="1" Background="#2a1d42" ResizeDirection="Columns" />

            <!-- Column 2: Element Tree -->
            <DockPanel Grid.Column="2" Background="#1a1030">
                <Border DockPanel.Dock="Top" Background="#120c22" Padding="6,6"
                        BorderBrush="#2a1d42" BorderThickness="0,0,0,1">
                    <TextBlock Text="Element Hierarchy" FontSize="13" FontWeight="SemiBold" Foreground="#c0b0d8" />
                </Border>

                <Panel>
                    <TextBlock Text="Select a layout from the list"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" Foreground="#5a4a6e" Opacity="0.6"
                               IsVisible="{Binding SelectedDetail, Converter={x:Static ObjectConverters.IsNull}}" />

                    <TreeView ItemsSource="{Binding SelectedDetail.RootElements}"
                              SelectedItem="{Binding SelectedDetail.SelectedElement}"
                              Background="Transparent" FontSize="11"
                              IsVisible="{Binding SelectedDetail, Converter={x:Static ObjectConverters.IsNotNull}}"
                              x:CompileBindings="False">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <!-- ToolTip on a wrapper: inner TextBlock in ToolTip.Tip often loses tree item DataContext in Avalonia TreeView. -->
                                <Border Background="Transparent" Margin="0,1" Padding="2,0"
                                        ToolTip.Placement="Right" ToolTip.ShowDelay="200"
                                        ToolTip.Tip="{Binding HierarchyTooltip}">
                                    <TextBlock Text="{Binding TreeLine}" FontFamily="Consolas" FontSize="11"
                                               Foreground="#b8c8e8" TextWrapping="Wrap" />
                                </Border>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Panel>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="1" Background="#2a1d42" ResizeDirection="Columns" />

            <!-- Column 4: Properties + Visual Preview -->
            <Grid Grid.Column="4" RowDefinitions="*,1,*" Background="#1a1030">

                <!-- Properties Panel (top) -->
                <Border Grid.Row="0">
                    <Panel>
                        <TextBlock Text="Select a layout from the list"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="12" Foreground="#5a4a6e" Opacity="0.6"
                                   IsVisible="{Binding SelectedDetail, Converter={x:Static ObjectConverters.IsNull}}" />

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding SelectedDetail, Converter={x:Static ObjectConverters.IsNotNull}}"
                                      x:CompileBindings="False">
                            <StackPanel Margin="10,6" Spacing="4">

                                <TextBlock Classes="section-header" Text="Layout canvas" />
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Classes="prop-label" Text="Width" Width="48" />
                                    <TextBox Text="{Binding SelectedDetail.LayoutWidthText}" Width="72" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="Height" Width="48" />
                                    <TextBox Text="{Binding SelectedDetail.LayoutHeightText}" Width="72" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <Button Content="Apply" Command="{Binding SelectedDetail.ApplyLayoutSizeCommand}"
                                            Padding="10,4" FontSize="11" />
                                </StackPanel>
                                <TextBlock Text="Preview: drag inside the selection to move; drag corners or edges to resize (layout pixels, clamped to canvas)."
                                           FontSize="10" Foreground="#6a5a7e" TextWrapping="Wrap" Margin="0,0,0,4" />

                                <TextBlock Text="Select an element in the tree to edit geometry and textures."
                                           HorizontalAlignment="Center"
                                           FontSize="12" Foreground="#5a4a6e" Opacity="0.75" Margin="0,8,0,0"
                                           IsVisible="{Binding SelectedDetail.SelectedElement, Converter={x:Static ObjectConverters.IsNull}}" />

                                <StackPanel Spacing="2"
                                            IsVisible="{Binding SelectedDetail.SelectedElement, Converter={x:Static ObjectConverters.IsNotNull}}">

                                <StackPanel DataContext="{Binding SelectedDetail.SelectedElement}">
                                <TextBlock Classes="section-header" Text="Identity" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="Element ID" />
                                    <TextBlock Classes="prop-value" Text="{Binding DisplayId}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="Type" />
                                    <TextBlock Classes="prop-value" Text="{Binding TypeHex}" />
                                </StackPanel>
                                <StackPanel Orientation="Vertical" Spacing="2" Margin="0,4,0,0">
                                    <TextBlock Classes="prop-label" Text="Effective type" />
                                    <TextBlock Classes="prop-value" Text="{Binding EffectiveTypeHint}" TextWrapping="Wrap" />
                                </StackPanel>
                                <!-- Do not use prop-label here: it sets Width=120 and clips long titles. -->
                                <StackPanel Orientation="Vertical" Spacing="4" Margin="0,8,0,0">
                                    <TextBlock Text="UI text (StringTable / MediaDescMessage)"
                                               FontSize="11" FontWeight="SemiBold" Foreground="#9a8aae" TextWrapping="Wrap" />
                                    <TextBlock FontSize="11" Foreground="#d4c4ec" LineHeight="16"
                                               Text="{Binding CaptionDisplay}" TextWrapping="Wrap" />
                                </StackPanel>
                                </StackPanel>

                                <TextBlock Classes="section-header" Text="Position / Size (apply)" />
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Classes="prop-label" Text="X" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomXText}" Width="56" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="Y" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomYText}" Width="56" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="W" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomWidthText}" Width="56" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="H" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomHeightText}" Width="56" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock Classes="prop-label" Text="Z" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomZText}" Width="56" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="Read order" Width="72" />
                                    <TextBox Text="{Binding SelectedDetail.ElementReadOrderText}" Width="56" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <Button Content="Apply geometry" Command="{Binding SelectedDetail.ApplyElementGeometryCommand}"
                                            Padding="10,4" FontSize="11" Margin="8,0,0,0" />
                                </StackPanel>

                                <TextBlock Classes="section-header" Text="Edges (anchors)" />
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Classes="prop-label" Text="L" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomLeftText}" Width="48" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="T" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomTopText}" Width="48" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="R" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomRightText}" Width="48" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                    <TextBlock Classes="prop-label" Text="B" Width="28" />
                                    <TextBox Text="{Binding SelectedDetail.ElementGeomBottomText}" Width="48" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3" />
                                </StackPanel>

                                <TextBlock Classes="section-header" Text="Textures / media" />
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Classes="prop-label" Text="Primary image" Width="100" />
                                    <TextBox Text="{Binding SelectedDetail.PrimarySurfaceHexText}" MinWidth="120" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3"
                                             Watermark="0x06001234" />
                                    <Button Content="Apply" Command="{Binding SelectedDetail.ApplyPrimarySurfaceCommand}"
                                            Padding="10,4" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock Classes="prop-label" Text="Add template image" Width="100" />
                                    <TextBox Text="{Binding SelectedDetail.NewTemplateImageHexText}" MinWidth="120" FontSize="11"
                                             FontFamily="Consolas" Padding="4,3"
                                             Watermark="0x06001234" />
                                    <Button Content="Add" Command="{Binding SelectedDetail.AddTemplateImageCommand}"
                                            Padding="10,4" FontSize="11" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,4,0,0">
                                    <Button Content="Replace image (in-place)…"
                                            Command="{Binding SelectedDetail.ReplaceUiRenderSurfaceCommand}"
                                            Padding="10,4" FontSize="11"
                                            ToolTip.Tip="Requires the primary image to resolve to an existing portal RenderSurface (usually 0x06……). Writes with a temporary read/write DAT connection (base client folder must be writable). Check the console for [TextureImport] Replace UI texture lines. Preview updates from your file after save." />
                                </StackPanel>
                                <TextBlock Text="Hex: Apply points the element at an id; Add appends template media. In-place replace works only for existing 0x06…… RenderSurfaces — inserting new portal textures can corrupt client_portal.dat for ACE."
                                           FontSize="10" Foreground="#6a5a7e" TextWrapping="Wrap" Margin="0,0,0,4" />

                                <TextBlock Classes="section-header" Text="Inheritance" />
                                <StackPanel DataContext="{Binding SelectedDetail.SelectedElement}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="Base Layout" />
                                    <TextBlock Classes="prop-value" Text="{Binding BaseLayoutHex}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="Base Element" />
                                    <TextBlock Classes="prop-value" Text="{Binding BaseElement}" />
                                </StackPanel>

                                <TextBlock Classes="section-header" Text="UI states &amp; media" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="Default UIState" />
                                    <TextBlock Classes="prop-value" Text="{Binding DefaultStateHex}" />
                                </StackPanel>
                                <TextBlock Text="Template row + one row per state. Image surface = first MediaDescImage. Message copy = MediaDescMessage.Id resolved via StringTable (client_local_English); StringInfo properties on the same state hint which table DID to try first."
                                           FontSize="10" Foreground="#6a5a7e" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding StateRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LayoutStateRow">
                                            <Border Background="#140a22" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                                                    BorderBrush="#2a1d42" BorderThickness="1">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding RowLabel}" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="#9ec0a8" />
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Classes="prop-label" Text="State id" Width="72" />
                                                        <TextBlock Classes="prop-value" Text="{Binding StateRecordIdHex}" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Classes="prop-label" Text="Image surface" Width="72" />
                                                        <TextBlock Classes="prop-value" Text="{Binding FirstImageSurfaceDisplay}" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Classes="prop-label" Text="Media" Width="72" />
                                                        <TextBlock Classes="prop-value" Text="{Binding MediaSummary}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Classes="section-header" Text="Contents" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="Children" />
                                    <TextBlock Classes="prop-value" Text="{Binding ChildrenCount}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="prop-label" Text="States" />
                                    <TextBlock Classes="prop-value" Text="{Binding StatesCount}" />
                                </StackPanel>
                                </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Panel>
                </Border>

                <GridSplitter Grid.Row="1" Height="1" Background="#2a1d42"
                              ResizeDirection="Rows" HorizontalAlignment="Stretch" />

                <!-- Visual Preview (bottom) -->
                <Border Grid.Row="2" Background="#0d0818"
                        BorderBrush="#2a1d42" BorderThickness="0,0,0,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#120c22" Padding="6,4"
                                BorderBrush="#2a1d42" BorderThickness="0,0,0,1">
                            <TextBlock Text="Visual Preview" FontSize="11" FontWeight="SemiBold" Foreground="#c0b0d8" />
                        </Border>
                        <vm:LayoutPreviewCanvas x:Name="PreviewCanvas" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
